{
  "name": "loom-vscode",
  "displayName": "Loom AI",
  "description": "Weave ideas into features with AI — document‑driven workflow for VS Code",
  "version": "0.7.0",
  "publisher": "reslava",
  "license": "MIT",
  "icon": "media/loom.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/reslava/loom"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:.loom/**",
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "loom",
          "title": "Loom",
          "icon": "media/loom-icon.svg"
        }
      ]
    },
    "views": {
      "loom": [
        {
          "id": "loom.threads",
          "name": "Threads"
        },
        {
          "id": "loom.context",
          "name": "Context"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "loom.threads",
        "contents": "No Loom workspace found.\n\nRun `loom install` to initialize Loom in this folder.\n\n[Initialize Workspace](command:loom.install.runInstall)",
        "when": "!loom.workspaceInitialized"
      },
      {
        "view": "loom.threads",
        "contents": "No weaves yet.\n\nCreate your first weave to start organizing your work.\n\n[New Weave](command:loom.weaveCreate)",
        "when": "loom.workspaceInitialized && !loom.hasWeaves"
      }
    ],
    "commands": [
      {
        "command": "loom.refresh",
        "title": "Refresh",
        "category": "Loom",
        "icon": "$(refresh)"
      },
      {
        "command": "loom.reconnectMcp",
        "title": "Reconnect MCP",
        "category": "Loom",
        "icon": "$(debug-restart)"
      },
      {
        "command": "loom.weaveCreate",
        "title": "New Weave",
        "category": "Loom",
        "icon": {
          "light": "media/icons/weave.svg",
          "dark": "media/icons/weave.svg"
        }
      },
      {
        "command": "loom.threadCreate",
        "title": "Weave Thread",
        "category": "Loom",
        "icon": {
          "light": "media/icons/thread.svg",
          "dark": "media/icons/thread.svg"
        }
      },
      {
        "command": "loom.delete",
        "title": "Delete",
        "category": "Loom",
        "icon": "$(trash)"
      },
      {
        "command": "loom.archive",
        "title": "Archive",
        "category": "Loom",
        "icon": {
          "light": "media/icons/archive.svg",
          "dark": "media/icons/archive.svg"
        }
      },
      {
        "command": "loom.weaveIdea",
        "title": "Weave Idea",
        "category": "Loom",
        "icon": {
          "light": "media/icons/idea.svg",
          "dark": "media/icons/idea.svg"
        }
      },
      {
        "command": "loom.weaveDesign",
        "title": "Weave Design",
        "category": "Loom",
        "icon": {
          "light": "media/icons/design.svg",
          "dark": "media/icons/design.svg"
        }
      },
      {
        "command": "loom.weavePlan",
        "title": "Weave Plan",
        "category": "Loom",
        "icon": {
          "light": "media/icons/plan.svg",
          "dark": "media/icons/plan.svg"
        }
      },
      {
        "command": "loom.rename",
        "title": "Rename Document",
        "category": "Loom",
        "icon": "$(edit)"
      },
      {
        "command": "loom.refineDesign",
        "title": "Refine Design",
        "category": "Loom",
        "icon": "$(symbol-structure)"
      },
      {
        "command": "loom.generateDesign",
        "title": "Generate Design (AI)",
        "category": "Loom",
        "icon": "$(sparkle)"
      },
      {
        "command": "loom.generatePlan",
        "title": "Generate Plan (AI)",
        "category": "Loom",
        "icon": "$(sparkle)"
      },
      {
        "command": "loom.startPlan",
        "title": "Start Plan",
        "category": "Loom",
        "icon": "$(play)"
      },
      {
        "command": "loom.completeStep",
        "title": "Complete Step",
        "category": "Loom",
        "icon": "$(pass)"
      },
      {
        "command": "loom.validate",
        "title": "Validate",
        "category": "Loom",
        "icon": "$(shield)"
      },
      {
        "command": "loom.setGrouping",
        "title": "Set Grouping",
        "category": "Loom",
        "icon": {
          "light": "media/icons/group.svg",
          "dark": "media/icons/group.svg"
        }
      },
      {
        "command": "loom.setTextFilter",
        "title": "Filter by text",
        "category": "Loom",
        "icon": "$(search)"
      },
      {
        "command": "loom.setStatusFilter",
        "title": "Filter by status",
        "category": "Loom",
        "icon": {
          "light": "media/icons/filter.svg",
          "dark": "media/icons/filter.svg"
        }
      },
      {
        "command": "loom.toggleArchived",
        "title": "Toggle Archived",
        "category": "Loom",
        "icon": {
          "light": "media/icons/archive.svg",
          "dark": "media/icons/archive.svg"
        }
      },
      {
        "command": "loom.toggleArchivedOff",
        "title": "Toggle Archived",
        "category": "Loom",
        "icon": "$(archive)"
      },
      {
        "command": "loom.chatNew",
        "title": "Weave Chat",
        "category": "Loom",
        "icon": {
          "light": "media/icons/chat.svg",
          "dark": "media/icons/chat.svg"
        }
      },
      {
        "command": "loom.chatReply",
        "title": "AI Reply",
        "category": "Loom",
        "icon": "$(sparkle)"
      },
      {
        "command": "loom.restoreItem",
        "title": "Restore from Archive",
        "category": "Loom",
        "icon": "$(discard)"
      },
      {
        "command": "loom.markDone",
        "title": "Mark Done",
        "category": "Loom",
        "icon": "$(pass-filled)"
      },
      {
        "command": "loom.markActive",
        "title": "Mark Active",
        "category": "Loom",
        "icon": "$(circle-large-outline)"
      },
      {
        "command": "loom.promoteToIdea",
        "title": "Promote to Idea",
        "category": "Loom",
        "icon": {
          "light": "media/icons/idea.svg",
          "dark": "media/icons/idea.svg"
        }
      },
      {
        "command": "loom.promoteToDesign",
        "title": "Promote to Design",
        "category": "Loom",
        "icon": {
          "light": "media/icons/design.svg",
          "dark": "media/icons/design.svg"
        }
      },
      {
        "command": "loom.promoteToPlan",
        "title": "Promote to Plan",
        "category": "Loom",
        "icon": {
          "light": "media/icons/plan.svg",
          "dark": "media/icons/plan.svg"
        }
      },
      {
        "command": "loom.promoteToReference",
        "title": "Promote to Reference",
        "category": "Loom",
        "icon": "$(library)"
      },
      {
        "command": "loom.refineIdea",
        "title": "Refine Idea",
        "category": "Loom",
        "icon": "$(edit)"
      },
      {
        "command": "loom.refinePlan",
        "title": "Refine Plan",
        "category": "Loom",
        "icon": "$(edit)"
      },
      {
        "command": "loom.doStep",
        "title": "Do Step(s)",
        "category": "Loom",
        "icon": "$(sparkle)"
      },
      {
        "command": "loom.closePlan",
        "title": "Close Plan",
        "category": "Loom",
        "icon": "$(archive)"
      },
      {
        "command": "loom.context.exclude",
        "title": "Exclude from context",
        "category": "Loom",
        "icon": "$(circle-slash)"
      },
      {
        "command": "loom.context.include",
        "title": "Include in context",
        "category": "Loom",
        "icon": "$(check)"
      },
      {
        "command": "loom.context.reset",
        "title": "Reset to auto",
        "category": "Loom",
        "icon": "$(discard)"
      },
      {
        "command": "loom.context.openDoc",
        "title": "Open Document",
        "category": "Loom"
      },
      {
        "command": "loom.createReference",
        "title": "Create Reference",
        "category": "Loom",
        "icon": "$(library)"
      },
      {
        "command": "loom.addRequiresLoad",
        "title": "Add References…",
        "category": "Loom",
        "icon": "$(link)"
      },
      {
        "command": "loom.refreshCtx",
        "title": "Refresh Context",
        "category": "Loom",
        "icon": "$(sync)"
      },
      {
        "command": "loom.toggleSyncDocToTree",
        "title": "Sync Doc → Tree (enabled)",
        "category": "Loom",
        "icon": "$(eye)"
      },
      {
        "command": "loom.toggleSyncDocToTreeOff",
        "title": "Sync Doc → Tree (disabled)",
        "category": "Loom",
        "icon": "$(eye-closed)"
      }
    ],
    "configuration": {
      "title": "Loom",
      "properties": {
        "reslava-loom.user.name": {
          "type": "string",
          "default": "",
          "description": "Your display name used in chat and document headers (e.g. 'Rafa')."
        },
        "reslava-loom.ai.provider": {
          "type": "string",
          "enum": [
            "anthropic",
            "deepseek",
            "openai"
          ],
          "default": "anthropic",
          "description": "AI provider. Claude (Anthropic) is recommended. DeepSeek and OpenAI also supported."
        },
        "reslava-loom.ai.apiKey": {
          "type": "string",
          "default": "",
          "description": "API key for the configured AI provider.",
          "markdownDescription": "API key for the configured AI provider. Store securely — do not commit to source control."
        },
        "reslava-loom.ai.model": {
          "type": "string",
          "default": "",
          "description": "Model name override. Leave blank to use the provider default (claude-haiku-4-5-20251001 / deepseek-chat / gpt-4o-mini)."
        },
        "reslava-loom.ai.baseUrl": {
          "type": "string",
          "default": "",
          "description": "Base URL override for OpenAI-compatible endpoints. Leave blank to use provider default."
        }
      }
    },
    "walkthroughs": [
      {
        "id": "loom.getStarted",
        "title": "Get Started with Loom",
        "description": "Set up AI-assisted, document-driven workflow in your workspace.",
        "steps": [
          {
            "id": "installCli",
            "title": "Install Loom CLI",
            "description": "Install the Loom CLI globally.\n\n[Open Terminal](command:loom.install.openCliTerminal)",
            "completionEvents": ["onContext:loom.cliDetected"],
            "media": { "image": "media/loom.png", "altText": "Loom" }
          },
          {
            "id": "initWorkspace",
            "title": "Initialize this workspace",
            "description": "Run `loom install` to create `.loom/`, write the session contract, and set up MCP.\n\n[Initialize](command:loom.install.runInstall)",
            "completionEvents": ["onContext:loom.workspaceInitialized"],
            "media": { "image": "media/loom.png", "altText": "Loom" }
          },
          {
            "id": "configureAi",
            "title": "Configure an AI provider",
            "description": "Add your Claude (Anthropic), DeepSeek, or OpenAI API key to enable AI commands.\n\n[Open Settings](command:loom.install.openAiSettings)",
            "completionEvents": ["onContext:loom.aiConfigured"],
            "media": { "image": "media/loom.png", "altText": "Loom" }
          },
          {
            "id": "createWeave",
            "title": "Create your first weave",
            "description": "Start a new project weave from the Loom panel toolbar.\n\n[New Weave](command:loom.weaveCreate)",
            "completionEvents": ["onContext:loom.hasWeaves"],
            "media": { "image": "media/loom.png", "altText": "Loom" }
          }
        ]
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "loom.weaveCreate",
          "when": "view == loom.threads && loom.workspaceInitialized",
          "group": "navigation@1"
        },
        {
          "command": "loom.setGrouping",
          "when": "view == loom.threads",
          "group": "navigation@2"
        },
        {
          "command": "loom.setStatusFilter",
          "when": "view == loom.threads",
          "group": "navigation@3"
        },
        {
          "command": "loom.setTextFilter",
          "when": "view == loom.threads",
          "group": "navigation@4"
        },
        {
          "command": "loom.toggleArchived",
          "when": "view == loom.threads && loom.showArchived",
          "group": "navigation@5"
        },
        {
          "command": "loom.toggleArchivedOff",
          "when": "view == loom.threads && !loom.showArchived",
          "group": "navigation@5"
        },
        {
          "command": "loom.toggleSyncDocToTree",
          "when": "view == loom.threads && loom.syncDocToTreeEnabled",
          "group": "navigation@6"
        },
        {
          "command": "loom.toggleSyncDocToTreeOff",
          "when": "view == loom.threads && !loom.syncDocToTreeEnabled",
          "group": "navigation@6"
        },
        {
          "command": "loom.refresh",
          "when": "view == loom.threads",
          "group": "navigation@7"
        }
      ],
      "view/item/context": [
        {
          "command": "loom.context.exclude",
          "when": "view == loom.context && viewItem =~ /^ctx-(auto|locked)$/",
          "group": "inline"
        },
        {
          "command": "loom.context.include",
          "when": "view == loom.context && viewItem =~ /^ctx-(excluded|available)$/",
          "group": "inline"
        },
        {
          "command": "loom.context.reset",
          "when": "view == loom.context && viewItem =~ /^ctx-(pinned|excluded|required)$/",
          "group": "inline"
        },
        {
          "command": "loom.chatNew",
          "when": "view == loom.threads && viewItem == chats-section",
          "group": "inline@1"
        },
        {
          "command": "loom.refreshCtx",
          "when": "view == loom.threads && viewItem == ctx-section",
          "group": "inline@1"
        },
        {
          "command": "loom.createReference",
          "when": "view == loom.threads && viewItem == refs-section",
          "group": "inline@1"
        },
        {
          "command": "loom.addRequiresLoad",
          "when": "view == loom.threads && viewItem =~ /^(idea|design|plan)/",
          "group": "edit@0"
        },
        {
          "command": "loom.weaveIdea",
          "when": "view == loom.threads && viewItem =~ /^thread/ && !(viewItem =~ /has-idea/)",
          "group": "inline@1"
        },
        {
          "command": "loom.weaveDesign",
          "when": "view == loom.threads && viewItem =~ /^thread/ && !(viewItem =~ /has-design/)",
          "group": "inline@2"
        },
        {
          "command": "loom.weavePlan",
          "when": "view == loom.threads && (viewItem =~ /^thread/ || viewItem == design)",
          "group": "inline@3"
        },
        {
          "command": "loom.weaveCreate",
          "when": "view == loom.threads && viewItem =~ /^weave/",
          "group": "create@1"
        },
        {
          "command": "loom.threadCreate",
          "when": "view == loom.threads && viewItem =~ /^weave/",
          "group": "create@2"
        },
        {
          "command": "loom.chatNew",
          "when": "view == loom.threads && viewItem =~ /^thread/",
          "group": "create@3"
        },
        {
          "command": "loom.weaveIdea",
          "when": "view == loom.threads && viewItem =~ /^thread/ && !(viewItem =~ /has-idea/)",
          "group": "create@1"
        },
        {
          "command": "loom.weaveDesign",
          "when": "view == loom.threads && viewItem =~ /^thread/ && !(viewItem =~ /has-design/)",
          "group": "create@2"
        },
        {
          "command": "loom.weavePlan",
          "when": "view == loom.threads && (viewItem =~ /^thread/ || viewItem == design)",
          "group": "create@3"
        },
        {
          "command": "loom.startPlan",
          "when": "view == loom.threads && viewItem =~ /^plan-(draft|active)$/",
          "group": "inline@1"
        },
        {
          "command": "loom.doStep",
          "when": "view == loom.threads && viewItem == plan-implementing-doable",
          "group": "inline@1"
        },
        {
          "command": "loom.completeStep",
          "when": "view == loom.threads && viewItem == plan-implementing-doable",
          "group": "inline@2"
        },
        {
          "command": "loom.chatReply",
          "when": "view == loom.threads && viewItem == chat",
          "group": "inline@1"
        },
        {
          "command": "loom.validate",
          "when": "view == loom.threads && viewItem =~ /^weave/",
          "group": "inline@2"
        },
        {
          "command": "loom.refineIdea",
          "when": "view == loom.threads && viewItem =~ /^(idea|loose-idea)/",
          "group": "ai@1"
        },
        {
          "command": "loom.generateDesign",
          "when": "view == loom.threads && viewItem =~ /^idea/",
          "group": "ai@2"
        },
        {
          "command": "loom.refineDesign",
          "when": "view == loom.threads && viewItem == design",
          "group": "ai@1"
        },
        {
          "command": "loom.generatePlan",
          "when": "view == loom.threads && viewItem == design",
          "group": "ai@2"
        },
        {
          "command": "loom.refinePlan",
          "when": "view == loom.threads && viewItem =~ /^plan-/",
          "group": "ai@1"
        },
        {
          "command": "loom.closePlan",
          "when": "view == loom.threads && viewItem =~ /^plan-(implementing|done)$/",
          "group": "ai@2"
        },
        {
          "command": "loom.promoteToIdea",
          "when": "view == loom.threads && viewItem == chat",
          "group": "ai@1"
        },
        {
          "command": "loom.promoteToDesign",
          "when": "view == loom.threads && viewItem =~ /^(chat|idea|loose-idea)/",
          "group": "ai@2"
        },
        {
          "command": "loom.promoteToPlan",
          "when": "view == loom.threads && viewItem =~ /^(chat|idea|loose-idea|design)/",
          "group": "ai@3"
        },
        {
          "command": "loom.promoteToReference",
          "when": "view == loom.threads && viewItem == chat-refs",
          "group": "ai@1"
        },
        {
          "command": "loom.restoreItem",
          "when": "view == loom.threads && viewItem =~ /^(weave-archived|thread)/",
          "group": "edit@0"
        },
        {
          "command": "loom.markDone",
          "when": "view == loom.threads && viewItem =~ /^(idea|design|plan|chat|reference)/",
          "group": "edit@1"
        },
        {
          "command": "loom.markActive",
          "when": "view == loom.threads && viewItem =~ /^(idea|design|plan|chat|reference)/",
          "group": "edit@2"
        },
        {
          "command": "loom.rename",
          "when": "view == loom.threads && viewItem =~ /^(weave|thread|idea|design|plan|chat|done|ctx|loose|reference)/",
          "group": "edit@3"
        },
        {
          "command": "loom.archive",
          "when": "view == loom.threads && viewItem =~ /^(weave|thread|idea|design|chat|done|ctx|loose|reference)/",
          "group": "edit@4"
        },
        {
          "command": "loom.delete",
          "when": "view == loom.threads && viewItem =~ /^(weave|thread|idea|design|plan|chat|done|ctx|loose|reference)/",
          "group": "edit@5"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "node esbuild.js --production",
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "typecheck": "tsc -p ./ --noEmit",
    "package": "npx @vscode/vsce package --no-dependencies",
    "publish": "npx @vscode/vsce publish --no-dependencies"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@reslava-loom/app": "file:../app",
    "@reslava-loom/core": "file:../core",
    "@reslava-loom/fs": "file:../fs",
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.5.0"
  }
}
