{
  "name": "loom-vscode",
  "displayName": "Loom",
  "description": "Weave ideas into features with AI — document‑driven workflow for VS Code",
  "version": "0.1.0",
  "publisher": "reslava",
  "license": "MIT",
  "icon": "media/loom.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/reslava/loom"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:.loom/**",
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "loom",
          "title": "Loom",
          "icon": "media/loom-icon.svg"
        }
      ]
    },
    "views": {
      "loom": [
        {
          "id": "loom.threads",
          "name": "Threads"
        }
      ]
    },
    "commands": [
      {
        "command": "loom.refresh",
        "title": "Refresh",
        "category": "Loom",
        "icon": "$(refresh)"
      },
      {
        "command": "loom.weaveCreate",
        "title": "New Weave",
        "category": "Loom",
        "icon": {
          "light": "media/icons/weave.svg",
          "dark": "media/icons/weave.svg"
        }
      },
      {
        "command": "loom.threadCreate",
        "title": "Weave Thread",
        "category": "Loom",
        "icon": {
          "light": "media/icons/thread.svg",
          "dark": "media/icons/thread.svg"
        }
      },
      {
        "command": "loom.delete",
        "title": "Delete",
        "category": "Loom",
        "icon": "$(trash)"
      },
      {
        "command": "loom.archive",
        "title": "Archive",
        "category": "Loom",
        "icon": {
          "light": "media/icons/archive.svg",
          "dark": "media/icons/archive.svg"
        }
      },
      {
        "command": "loom.weaveIdea",
        "title": "Weave Idea",
        "category": "Loom",
        "icon": {
          "light": "media/icons/idea.svg",
          "dark": "media/icons/idea.svg"
        }
      },
      {
        "command": "loom.weaveDesign",
        "title": "Weave Design",
        "category": "Loom",
        "icon": {
          "light": "media/icons/design.svg",
          "dark": "media/icons/design.svg"
        }
      },
      {
        "command": "loom.weavePlan",
        "title": "Weave Plan",
        "category": "Loom",
        "icon": {
          "light": "media/icons/plan.svg",
          "dark": "media/icons/plan.svg"
        }
      },
      {
        "command": "loom.finalize",
        "title": "Finalize Document",
        "category": "Loom",
        "icon": "$(check)"
      },
      {
        "command": "loom.rename",
        "title": "Rename Document",
        "category": "Loom",
        "icon": "$(edit)"
      },
      {
        "command": "loom.refineDesign",
        "title": "Refine Design",
        "category": "Loom",
        "icon": "$(symbol-structure)"
      },
      {
        "command": "loom.startPlan",
        "title": "Start Plan",
        "category": "Loom",
        "icon": "$(play)"
      },
      {
        "command": "loom.completeStep",
        "title": "Complete Step",
        "category": "Loom",
        "icon": "$(pass)"
      },
      {
        "command": "loom.validate",
        "title": "Validate",
        "category": "Loom",
        "icon": "$(shield)"
      },
      {
        "command": "loom.summarise",
        "title": "Summarise Context",
        "category": "Loom",
        "icon": "$(book)"
      },
      {
        "command": "loom.setGrouping",
        "title": "Set Grouping",
        "category": "Loom",
        "icon": {
          "light": "media/icons/group.svg",
          "dark": "media/icons/group.svg"
        }
      },
      {
        "command": "loom.setTextFilter",
        "title": "Filter",
        "category": "Loom",
        "icon": {
          "light": "media/icons/filter.svg",
          "dark": "media/icons/filter.svg"
        }
      },
      {
        "command": "loom.toggleArchived",
        "title": "Toggle Archived",
        "category": "Loom",
        "icon": {
          "light": "media/icons/archive.svg",
          "dark": "media/icons/archive.svg"
        }
      },
      {
        "command": "loom.chatNew",
        "title": "Weave Chat",
        "category": "Loom",
        "icon": {
          "light": "media/icons/chat.svg",
          "dark": "media/icons/chat.svg"
        }
      },
      {
        "command": "loom.chatReply",
        "title": "AI Reply",
        "category": "Loom",
        "icon": "$(sparkle)"
      },
      {
        "command": "loom.promoteToIdea",
        "title": "Promote to Idea",
        "category": "Loom",
        "icon": {
          "light": "media/icons/idea.svg",
          "dark": "media/icons/idea.svg"
        }
      },
      {
        "command": "loom.promoteToDesign",
        "title": "Promote to Design",
        "category": "Loom",
        "icon": {
          "light": "media/icons/design.svg",
          "dark": "media/icons/design.svg"
        }
      },
      {
        "command": "loom.promoteToPlan",
        "title": "Promote to Plan",
        "category": "Loom",
        "icon": {
          "light": "media/icons/plan.svg",
          "dark": "media/icons/plan.svg"
        }
      },
      {
        "command": "loom.refineIdea",
        "title": "Refine Idea",
        "category": "Loom",
        "icon": "$(edit)"
      },
      {
        "command": "loom.refinePlan",
        "title": "Refine Plan",
        "category": "Loom",
        "icon": "$(edit)"
      },
      {
        "command": "loom.doStep",
        "title": "Do Step(s)",
        "category": "Loom",
        "icon": "$(sparkle)"
      },
      {
        "command": "loom.closePlan",
        "title": "Close Plan",
        "category": "Loom",
        "icon": "$(archive)"
      }
    ],
    "configuration": {
      "title": "Loom",
      "properties": {
        "reslava-loom.user.name": {
          "type": "string",
          "default": "",
          "description": "Your display name used in chat and document headers (e.g. 'Rafa')."
        },
        "reslava-loom.ai.provider": {
          "type": "string",
          "enum": [
            "deepseek",
            "openai"
          ],
          "default": "deepseek",
          "description": "AI provider. DeepSeek is recommended for cost-effective testing."
        },
        "reslava-loom.ai.apiKey": {
          "type": "string",
          "default": "",
          "description": "API key for the configured AI provider.",
          "markdownDescription": "API key for the configured AI provider. Store securely — do not commit to source control."
        },
        "reslava-loom.ai.model": {
          "type": "string",
          "default": "",
          "description": "Model name override. Leave blank to use the provider default (deepseek-chat / gpt-4o-mini)."
        },
        "reslava-loom.ai.baseUrl": {
          "type": "string",
          "default": "",
          "description": "Base URL override for OpenAI-compatible endpoints. Leave blank to use provider default."
        }
      }
    },
    "walkthroughs": [
      {
        "id": "loom.getStarted",
        "title": "Get Started with Loom",
        "description": "Set up AI-assisted, document-driven workflow in your workspace.",
        "steps": [
          {
            "id": "installCli",
            "title": "Install Loom CLI",
            "description": "Install the Loom CLI globally.\n\n[Open Terminal](command:loom.install.openCliTerminal)",
            "completionEvents": ["onContext:loom.cliDetected"],
            "media": { "image": "media/loom.png", "altText": "Loom" }
          },
          {
            "id": "initWorkspace",
            "title": "Initialize this workspace",
            "description": "Run `loom install` to create `.loom/`, write the session contract, and set up MCP.\n\n[Initialize](command:loom.install.runInstall)",
            "completionEvents": ["onContext:loom.workspaceInitialized"],
            "media": { "image": "media/loom.png", "altText": "Loom" }
          },
          {
            "id": "configureAi",
            "title": "Configure an AI provider",
            "description": "Add your DeepSeek or OpenAI API key to enable AI commands.\n\n[Open Settings](command:loom.install.openAiSettings)",
            "completionEvents": ["onContext:loom.aiConfigured"],
            "media": { "image": "media/loom.png", "altText": "Loom" }
          },
          {
            "id": "createWeave",
            "title": "Create your first weave",
            "description": "Start a new project weave from the Loom panel toolbar.\n\n[New Weave](command:loom.weaveCreate)",
            "completionEvents": ["onContext:loom.hasWeaves"],
            "media": { "image": "media/loom.png", "altText": "Loom" }
          }
        ]
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "loom.weaveCreate",
          "when": "view == loom.threads",
          "group": "navigation@0"
        },
        {
          "command": "loom.threadCreate",
          "when": "view == loom.threads && loom.selectedWeaveId",
          "group": "navigation@1"
        },
        {
          "command": "loom.chatNew",
          "when": "view == loom.threads && loom.selectedWeaveId",
          "group": "navigation@2"
        },
        {
          "command": "loom.weaveIdea",
          "when": "view == loom.threads",
          "group": "navigation@3"
        },
        {
          "command": "loom.weaveDesign",
          "when": "view == loom.threads",
          "group": "navigation@4"
        },
        {
          "command": "loom.weavePlan",
          "when": "view == loom.threads",
          "group": "navigation@5"
        },
        {
          "command": "loom.setGrouping",
          "when": "view == loom.threads",
          "group": "navigation@6"
        },
        {
          "command": "loom.setTextFilter",
          "when": "view == loom.threads",
          "group": "navigation@7"
        },
        {
          "command": "loom.toggleArchived",
          "when": "view == loom.threads",
          "group": "navigation@8"
        },
        {
          "command": "loom.refresh",
          "when": "view == loom.threads",
          "group": "navigation@9"
        }
      ],
      "view/item/context": [
        {
          "command": "loom.weaveIdea",
          "when": "view == loom.threads && viewItem == thread",
          "group": "inline@1"
        },
        {
          "command": "loom.weaveDesign",
          "when": "view == loom.threads && viewItem == thread",
          "group": "inline@2"
        },
        {
          "command": "loom.weavePlan",
          "when": "view == loom.threads && (viewItem == thread || viewItem == design)",
          "group": "inline@3"
        },
        {
          "command": "loom.summarise",
          "when": "view == loom.threads && (viewItem == weave || viewItem == thread) && loom.aiEnabled",
          "group": "inline@4"
        },
        {
          "command": "loom.finalize",
          "when": "view == loom.threads && viewItem =~ /^(idea|design|loose-idea|loose-design)-temp$/",
          "group": "inline@1"
        },
        {
          "command": "loom.refineDesign",
          "when": "view == loom.threads && viewItem == design",
          "group": "inline@2"
        },
        {
          "command": "loom.startPlan",
          "when": "view == loom.threads && viewItem =~ /^plan-(draft|active)$/",
          "group": "inline@1"
        },
        {
          "command": "loom.doStep",
          "when": "view == loom.threads && viewItem == plan-implementing && loom.aiEnabled",
          "group": "inline@1"
        },
        {
          "command": "loom.completeStep",
          "when": "view == loom.threads && viewItem == plan-implementing",
          "group": "inline@2"
        },
        {
          "command": "loom.validate",
          "when": "view == loom.threads && viewItem == weave",
          "group": "inline@2"
        },
        {
          "command": "loom.chatReply",
          "when": "view == loom.threads && viewItem == chat && loom.aiEnabled",
          "group": "inline@1"
        },
        {
          "command": "loom.promoteToIdea",
          "when": "view == loom.threads && viewItem == chat && loom.aiEnabled",
          "group": "inline@2"
        },
        {
          "command": "loom.promoteToDesign",
          "when": "view == loom.threads && viewItem =~ /^(chat|idea|loose-idea)/ && loom.aiEnabled",
          "group": "inline@3"
        },
        {
          "command": "loom.promoteToPlan",
          "when": "view == loom.threads && viewItem =~ /^(chat|idea|loose-idea|design)/ && loom.aiEnabled",
          "group": "inline@4"
        },
        {
          "command": "loom.refineIdea",
          "when": "view == loom.threads && viewItem =~ /^(idea|loose-idea)/ && loom.aiEnabled",
          "group": "inline@1"
        },
        {
          "command": "loom.refinePlan",
          "when": "view == loom.threads && viewItem =~ /^plan-/ && loom.aiEnabled",
          "group": "inline@2"
        },
        {
          "command": "loom.closePlan",
          "when": "view == loom.threads && viewItem =~ /^plan-(implementing|done)$/ && loom.aiEnabled",
          "group": "inline@3"
        },
        {
          "command": "loom.rename",
          "when": "view == loom.threads && viewItem =~ /^(weave|thread|idea|design|plan|chat|done|ctx|loose)/",
          "group": "inline@8"
        },
        {
          "command": "loom.archive",
          "when": "view == loom.threads && viewItem =~ /^(weave|thread|idea|design|chat|done|ctx|loose)/",
          "group": "inline@9"
        },
        {
          "command": "loom.delete",
          "when": "view == loom.threads && viewItem =~ /^(weave|thread|idea|design|plan|chat|done|ctx|loose)/",
          "group": "inline@10"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "node esbuild.js --production",
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "typecheck": "tsc -p ./ --noEmit",
    "package": "npx @vscode/vsce package --no-dependencies"
  },
  "dependencies": {
    "@reslava-loom/app": "file:../app",
    "@reslava-loom/core": "file:../core",
    "@reslava-loom/fs": "file:../fs"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.5.0"
  }
}
